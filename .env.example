# MĀMĀ Wool Sneakers — Environment Configuration
#
# Copy this file to `.env` and fill in real values for development.
# Values here are examples only — do NOT commit sensitive credentials.

# API base URL (if/when switching from in-memory to real API)
# VITE_API_URL=https://api.mama-sg.com/v1

# Stripe public key (optional — checkout is currently simulated)
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxx

# Feature flags
# VITE_ENABLE_ANALYTICS=false